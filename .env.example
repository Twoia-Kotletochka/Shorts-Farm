# ===== Shorts Farm — пример переменных окружения =====
# Скопируй в .env и заполни. Файл .env в git НЕ коммитится.

# Ключ шифрования секретов в БД (Fernet). Сгенерировать:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Путь хранилища ВНУТРИ контейнера (менять не нужно)
STORAGE_PATH=/srv/storage
# Путь хранилища на ХОСТЕ (монтируется как volume в api/worker)
STORAGE_PATH_HOST=/srv/storage/shorts-farm

# БД. По умолчанию SQLite внутри хранилища (пишем с прицелом на лёгкий переезд на PostgreSQL).
# Пример для PostgreSQL: postgresql+psycopg://user:pass@db:5432/shorts_farm
DATABASE_URL=sqlite:////srv/storage/db/shorts_farm.db

# Redis — брокер и backend Celery
REDIS_URL=redis://redis:6379/0

# Сеть: интерфейс хоста, на котором публикуется API.
# Для доступа из LAN укажи IP сервера; 127.0.0.1 — только локально (панель не наружу).
API_BIND_HOST=192.168.0.92
API_PORT=8000

# Параллелизм рендер-воркера. CPU-only: держать 1–2.
WORKER_CONCURRENCY=2

# GID групп хоста для доступа контейнера к /dev/dri (VAAPI-энкод).
# На этом сервере: video=44, render=992. ffmpeg сам откатится на libx264, если VAAPI недоступен.
VIDEO_GID=44
RENDER_GID=992

# Окружение
APP_ENV=production
DEBUG=0

# ===== Фронтенд (веб-панель) =====
# Порт dev-сервера Vite (публикуется на API_BIND_HOST, т.е. в LAN; не наружу).
FRONTEND_PORT=5173
# Mock-режим панели: 1 = данные из MSW в браузере (бэкенд не обязателен),
# 0 = живой API через прокси Vite на сервис api. До готовности роутов бэкенда держи 1.
VITE_API_MOCK=1
